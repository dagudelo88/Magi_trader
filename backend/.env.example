# Binance API Configuration
# NEVER commit the actual `.env` file to source control.
#
# Differentiate testnet vs mainnet credentials (recommended):
# • Use BINANCE_TESTNET_* for https://testnet.binance.vision/ (Spot testnet).
# • Use BINANCE_API_KEY / BINANCE_API_SECRET for https://www.binance.com/ (Spot mainnet / Live mode in UI).
#
# Execution mode (Testnet vs Live) is chosen in the app Settings and stored in SQLite — the backend
# picks the matching key pair below automatically.
#
# You can put this file at repo root (.env) or as backend/.env — both are loaded (backend overrides repo root).

# --- Spot testnet (preferred when app is in Testnet mode) ---
BINANCE_TESTNET_API_KEY=your_testnet_key_here
BINANCE_TESTNET_API_SECRET=your_testnet_secret_here

# --- Spot mainnet (used only when Live mode is enabled in Settings after confirmation) ---
BINANCE_API_KEY=your_mainnet_key_here
BINANCE_API_SECRET=your_mainnet_secret_here

# Optional alias for mainnet secret (some docs use this name):
# BINANCE_SECRET=

# Used by services/data_collector.py WebSocket URL (true = stream.testnet.binance.vision)
TESTNET=true

# Bot worker (services/bot_runner.py): frequent debug lines in Bot logs (cooldown, OHLCV, hold + SMAs).
# Set to 0 / false / no / off to reduce log volume.
BOT_DEBUG_LOGS=1

# Min seconds between repeated "waiting" summaries (global halt, no running bots, post-trade cooldown).
BOT_IDLE_LOG_INTERVAL_SEC=45

# Browser origins allowed for CORS (comma-separated). Required when the frontend runs on a different port than the API.
# Example: CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000
# If unset, defaults include localhost:5000 (Vite preview) and :5173/:4173 (Vite dev/preview).
# CORS_ORIGINS=
