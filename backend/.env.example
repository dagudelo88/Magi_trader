# Binance API Configuration
# Get these keys from your Binance account settings (API Management).
# NEVER commit the actual `.env` file to source control.
#
# You can put this file at repo root (.env) or here as backend/.env — both are loaded.
# Secret: use either BINANCE_API_SECRET or BINANCE_SECRET (docs / older samples used the latter).
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
